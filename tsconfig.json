{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "src/server/**/*.ts",
    "src/server/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "client/node_modules",
    "client/src"
  ]
}
